# Server Configuration
PORT=5000
NODE_ENV=development
# En production (NODE_ENV=production), POST /api/auth/register est refusé — créer les comptes via l’admin (POST /api/users).

# Database (PostgreSQL)
# En production (Render) : copier l'Internal Database URL depuis le dashboard Render
# Exemple avec ton instance (remplacer USER et PASSWORD par ceux affichés sur Render) :
# DATABASE_URL=postgresql://USER:PASSWORD@dpg-d6djsd4tgctc73f6ovp0-a.oregon-postgres.render.com/global_exchange?sslmode=require
#
# Option 2 : variables séparées (local ou si pas DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=global_exchange
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS) — même origine que l’URL du site (sans slash final OK). Aligner avec VITE_API_URL côté front.
FRONTEND_URL=http://localhost:5173

# Migrations SQL 002→009 au démarrage (VPS / Docker avec volume). Désactivé par défaut.
# RUN_MIGRATIONS_ON_START=1

# Schéma incomplet → /api/health en 503 (load balancer / monitoring). Optionnel.
# STRICT_HEALTH_SCHEMA=1

# Fichiers uploadés : chemin persistant (disque monté). Sinon défaut = backend/secure_uploads
# SECURE_UPLOADS_ROOT=/var/lib/globalexchange/uploads

# Pool (optionnel)
# DB_POOL_MAX=20
# DB_POOL_MIN=2

# Taux USD/XOF (optionnel) - si défini, remplace l'API (ex: 557.13)
# EXCHANGE_RATE_USD_XOF=557.13

# WhatsApp : choisir Twilio (sandbox = pas de template) ou WhatChimp (templates validés)
# WHATSAPP_PROVIDER=twilio
# WHATSAPP_PROVIDER=whatchimp

# --- Twilio (sandbox = message libre sans template, numéros ayant rejoint le sandbox)
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- WhatChimp (template WhatsApp validé requis)
# WHATCHIMP_ENABLED=true
# WHATCHIMP_WEBHOOK_URL=https://...
